@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click This Button</button>
//So the above stays in HTLM and then switches to C#, using the onclick function like c#

@code {
    private int currentCount = 0;

    [Parameter]
    public int incrementAmount { get; set; } = 1;

    private void IncrementCount()
    {
        currentCount = currentCount + incrementAmount;
    }
}
